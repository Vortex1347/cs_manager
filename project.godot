; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows for manual editing.

[configuration]

config_version=5

[application]

config/name="CS Manager"
config/version="0.1.0"
run/main_scene="res://scenes/game/game_manager.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[input]

pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)
]
}
open_upgrades={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[layer_names]

3d_physics/layer_1="walls"
3d_physics/layer_2="smoke"
3d_physics/layer_3="bots_ct"
3d_physics/layer_4="bots_t"
3d_physics/layer_5="zones"
3d_physics/layer_6="projectiles"

[physics]

3d/default_gravity=0.0

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.15, 0.15, 0.18, 1)
